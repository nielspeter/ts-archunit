{
  "name": "ts-archunit",
  "version": "0.1.0",
  "description": "Architecture testing for TypeScript",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./rules/typescript": {
      "types": "./dist/rules/typescript.d.ts",
      "import": "./dist/rules/typescript.js"
    },
    "./rules/security": {
      "types": "./dist/rules/security.d.ts",
      "import": "./dist/rules/security.js"
    },
    "./rules/errors": {
      "types": "./dist/rules/errors.d.ts",
      "import": "./dist/rules/errors.js"
    },
    "./rules/naming": {
      "types": "./dist/rules/naming.d.ts",
      "import": "./dist/rules/naming.js"
    },
    "./rules/dependencies": {
      "types": "./dist/rules/dependencies.d.ts",
      "import": "./dist/rules/dependencies.js"
    },
    "./rules/code-quality": {
      "types": "./dist/rules/code-quality.d.ts",
      "import": "./dist/rules/code-quality.js"
    },
    "./rules/metrics": {
      "types": "./dist/rules/metrics.d.ts",
      "import": "./dist/rules/metrics.js"
    },
    "./graphql": {
      "types": "./dist/graphql/index.d.ts",
      "import": "./dist/graphql/index.js"
    }
  },
  "bin": {
    "ts-archunit": "./dist/cli/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NielsPeter/ts-archunit"
  },
  "homepage": "https://github.com/NielsPeter/ts-archunit#readme",
  "bugs": {
    "url": "https://github.com/NielsPeter/ts-archunit/issues"
  },
  "author": "Niels Peter",
  "scripts": {
    "prepublishOnly": "npm run validate && npm run build",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "fix": "npm run lint:fix && npm run format",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli/bin.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "typescript",
    "architecture",
    "testing",
    "archunit",
    "static-analysis"
  ],
  "license": "MIT",
  "peerDependencies": {
    "graphql": "^16.0.0"
  },
  "peerDependenciesMeta": {
    "graphql": {
      "optional": true
    }
  },
  "dependencies": {
    "picomatch": "^4.0.4",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.15",
    "@types/picomatch": "^4.0.2",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "graphql": "^16.13.2",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.1"
  }
}
